<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- ═══ VUE POPUP : AJOUTER UNE LIGNE ═══ -->
    <record id="view_resade_budget_ligne_create_form" model="ir.ui.view">
        <field name="name">resade.budget.ligne.create.form</field>
        <field name="model">resade.budget.ligne</field>
        <field name="arch" type="xml">
            <form string="Ajouter une ligne budgétaire">
                <group>
                    <field name="budget_annuel_id" invisible="1"/>
                    <field name="name" required="1" placeholder="Intitulé de la ligne"/>
                    <field name="code_sycebnl" placeholder="Code SYCEBNL"/>
                    <field name="rubrique" required="1" placeholder="Rubrique budgétaire"/>
                    <field name="sous_rubrique" placeholder="Sous-rubrique"/>
                    <field name="department_id" readonly="1"/>
                    <field name="code_analytique" placeholder="Code analytique SAGE"/>
                    <field name="montant_prevu" required="1" placeholder="Montant prévu"/>
                    <field name="note" placeholder="Justification / note"/>
                    <field name="ressource_confirmee" invisible="1"/>
                </group>
                <footer>
                    <button string="Créer la ligne" class="btn-primary" type="object" name="action_create_ligne"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_resade_budget_ligne_list" model="ir.ui.view">
        <field name="name">resade.budget.ligne.list</field>
        <field name="model">resade.budget.ligne</field>
        <field name="arch" type="xml">
            <list string="Lignes Budgétaires" decoration-danger="alerte_seuil in ('alerte_95','depasse')"
                  decoration-warning="alerte_seuil == 'alerte_80'">
                <field name="name"/>
                <field name="budget_annuel_id"/>
                <field name="rubrique"/>
                <field name="departement"/>
                <field name="code_analytique"/>
                <field name="montant_prevu" sum="Total"/>
                <field name="montant_engage" sum="Total"/>
                <field name="montant_realise" sum="Total"/>
                <field name="montant_disponible" sum="Total"/>
                <field name="taux_consommation" widget="percentage"/>
                <field name="alerte_seuil" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_resade_budget_ligne_form" model="ir.ui.view">
        <field name="name">resade.budget.ligne.form</field>
        <field name="model">resade.budget.ligne</field>
        <field name="arch" type="xml">
            <form string="Ligne Budgétaire">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="budget_annuel_id"/>
                            <field name="rubrique"/>
                            <field name="sous_rubrique"/>
                            <field name="code_sycebnl"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group string="Imputation analytique">
                            <field name="code_analytique"/>
                            <field name="analytic_account_id"/>
                            <field name="ressource_confirmee"/>
                        </group>
                    </group>
                    <group string="Montants">
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="montant_prevu"/>
                            <field name="montant_engage" readonly="1"/>
                            <field name="montant_realise" readonly="1"/>
                            <field name="montant_disponible" readonly="1"/>
                        </group>
                        <group>
                            <field name="taux_consommation" readonly="1" widget="percentage"/>
                            <field name="alerte_seuil" readonly="1"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ ACTION : CRÉER UNE LIGNE ═══ -->
    <record id="action_resade_budget_ligne_create" model="ir.actions.act_window">
        <field name="name">Ajouter une ligne budgétaire</field>
        <field name="res_model">resade.budget.ligne</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_resade_budget_ligne_create_form"/>
        <field name="context">{'default_budget_annuel_id': active_id}</field>
    </record>

    <!-- ═══ ACTION : LIGNES DU DÉPARTEMENT (CHEF) ═══ -->
    <record id="action_resade_budget_ligne_chef" model="ir.actions.act_window">
        <field name="name">Lignes de mon département</field>
        <field name="res_model">resade.budget.ligne</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="domain">[('departement', '=', user.departement)]</field> -->
        <field name="context">{'default_budget_annuel_id': active_id}</field>
        <field name="help" type="html">
            <p>Gérez les lignes budgétaires de votre département.</p>
        </field>
    </record>

    <!-- ═══ ACTION : TOUTES LES LIGNES (CAF) ═══ -->
    <record id="action_resade_budget_ligne_all" model="ir.actions.act_window">
        <field name="name">Toutes les lignes budgétaires</field>
        <field name="res_model">resade.budget.ligne</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'default_budget_annuel_id': active_id}</field>
        <field name="help" type="html">
            <p>Gérez toutes les lignes budgétaires.</p>
        </field>
    </record>

    <record id="view_resade_budget_ligne_search" model="ir.ui.view">
        <field name="name">resade.budget.ligne.search</field>
        <field name="model">resade.budget.ligne</field>
        <field name="arch" type="xml">
            <search string="Rechercher Lignes Budgétaires">
                <field name="name"/>
                <field name="code_analytique"/>
                <field name="budget_annuel_id"/>
                <filter string="Alerte ≥ 80%" name="alerte" domain="[('alerte_seuil', '!=', 'ok')]"/>
                <filter string="Dépassées" name="depasse" domain="[('alerte_seuil', '=', 'depasse')]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Budget annuel" name="group_budget" context="{'group_by': 'budget_annuel_id'}"/>
                    <filter string="Rubrique" name="group_rubrique" context="{'group_by': 'rubrique'}"/>
                    <filter string="Département" name="group_dept" context="{'group_by': 'departement'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>

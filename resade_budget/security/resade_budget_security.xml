<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ═══════════════════════════════════════════
             CATÉGORIE
        ═══════════════════════════════════════════ -->
        <record id="module_resade_budget" model="ir.module.category">
            <field name="name">RESADE Budget</field>
            <field name="description">Élaboration, exécution et suivi du budget RESADE – Carnet C</field>
            <field name="sequence">88</field>
        </record>

        <!-- ═══════════════════════════════════════════
             GROUPES (hiérarchie implicite, conforme RACI Manuel)
        ═══════════════════════════════════════════ -->

        <!-- Demandeur : tout agent pouvant soumettre une FEB -->
        <record id="group_resade_budget_demandeur" model="res.groups">
            <field name="name">Demandeur</field>
            <field name="category_id" ref="module_resade_budget"/>
            <field name="comment">Tout agent : soumet une FEB (P-ESB-01), consulte ses demandes</field>
        </record>

        <!-- Chef de département : soumet le budget départemental, co-valide FEB -->
        <record id="group_resade_budget_chef_dept" model="res.groups">
            <field name="name">Chef de Département</field>
            <field name="category_id" ref="module_resade_budget"/>
            <field name="implied_ids" eval="[(4, ref('group_resade_budget_demandeur'))]"/>
            <field name="comment">Soumet le budget départemental (P-EAB-01) ; identifie les besoins de révision (P-ESB-03)</field>
        </record>

        <!-- CAF : pilotage technique principal de tous les processus budgétaires -->
        <record id="group_resade_budget_caf" model="res.groups">
            <field name="name">CAF (Administration &amp; Finances)</field>
            <field name="category_id" ref="module_resade_budget"/>
            <field name="implied_ids" eval="[(4, ref('group_resade_budget_chef_dept'))]"/>
            <field name="comment">Pilotage technique : consolidation budget, visa FEB (disponibilité crédits), TDB mensuel, révisions</field>
        </record>

        <!-- DE : arbitrage, validation, autorisation -->
        <record id="group_resade_budget_de" model="res.groups">
            <field name="name">Directeur Exécutif (DE)</field>
            <field name="category_id" ref="module_resade_budget"/>
            <field name="implied_ids" eval="[(4, ref('group_resade_budget_caf'))]"/>
            <field name="comment">Arbitrage et validation du budget (P-EAB-01) ; autorisation des dépenses (P-ESB-01) ; validation TDB et révisions</field>
        </record>

        <!-- CA / Administrateur : approbation finale, accès complet -->
        <record id="group_resade_budget_admin" model="res.groups">
            <field name="name">Conseil d'Administration / Administrateur</field>
            <field name="category_id" ref="module_resade_budget"/>
            <field name="implied_ids" eval="[(4, ref('group_resade_budget_de'))]"/>
            <field name="comment">Approbation formelle du budget annuel et des révisions institutionnelles (CA)</field>
        </record>

        <!-- ═══════════════════════════════════════════
             RÈGLES D'ACCÈS PAR ENREGISTREMENT
        ═══════════════════════════════════════════ -->

        <!-- FEB : un demandeur ne voit que ses propres FEB -->
        <record id="rule_budget_feb_demandeur_own" model="ir.rule">
            <field name="name">Demandeur : voir ses propres FEB</field>
            <field name="model_id" ref="model_resade_budget_feb"/>
            <field name="groups" eval="[(4, ref('group_resade_budget_demandeur'))]"/>
            <field name="domain_force">[('demandeur_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- CAF et au-dessus : voient toutes les FEB -->
        <record id="rule_budget_feb_caf_all" model="ir.rule">
            <field name="name">CAF / DE / Admin : voir toutes les FEB</field>
            <field name="model_id" ref="model_resade_budget_feb"/>
            <field name="groups" eval="[(4, ref('group_resade_budget_caf'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Budget annuel / Lignes / Projets bailleurs / TDB / Révisions :
             réservés au CAF et au-dessus (Chef dépt. en lecture pour son département) -->
        <record id="rule_budget_ligne_chef_dept_own" model="ir.rule">
            <field name="name">Chef Département : voir/modifier les lignes de son département</field>
            <field name="model_id" ref="model_resade_budget_ligne"/>
            <field name="groups" eval="[(4, ref('group_resade_budget_chef_dept'))]"/>
            <!-- 🔽 Utilisation du department_id de l'employé lié à l'utilisateur 🔽 -->
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_budget_annuel_caf_all" model="ir.rule">
            <field name="name">CAF / DE / Admin : gestion complète du budget annuel</field>
            <field name="model_id" ref="model_resade_budget_annuel"/>
            <field name="groups" eval="[(4, ref('group_resade_budget_caf'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>

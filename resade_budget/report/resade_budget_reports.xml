<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_resade_budget_feb" model="ir.actions.report">
        <field name="name">Fiche d'Expression des Besoins (RESADE-F-ESB-01-01)</field>
        <field name="model">resade.budget.feb</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">resade_budget.report_resade_budget_feb_template</field>
        <field name="report_file">resade_budget.report_resade_budget_feb_template</field>
        <field name="print_report_name">'%s' % (object.name or 'FEB').replace('/', '-')</field>
        <field name="binding_model_id" ref="model_resade_budget_feb"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_resade_budget_feb_registre" model="ir.actions.report">
        <field name="name">Registre des FEB (RESADE-F-ESB-01-02)</field>
        <field name="model">resade.budget.feb</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">resade_budget.report_resade_budget_feb_registre_template</field>
        <field name="report_file">resade_budget.report_resade_budget_feb_registre_template</field>
        <field name="print_report_name">'Registre_FEB'</field>
        <field name="binding_model_id" ref="model_resade_budget_feb"/>
        <field name="binding_type">report</field>
    </record>

</odoo>

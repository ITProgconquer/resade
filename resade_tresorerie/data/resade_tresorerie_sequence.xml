<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_resade_tresorerie_rapprochement" model="ir.sequence">
        <field name="name">RESADE Rapprochement bancaire</field>
        <field name="code">resade.tresorerie.rapprochement</field>
        <field name="prefix">RAPP-%(year)s-</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_resade_tresorerie_caisse_decaissement" model="ir.sequence">
        <field name="name">RESADE Décaissement de caisse</field>
        <field name="code">resade.tresorerie.caisse.decaissement</field>
        <field name="prefix">DEC-CAISSE-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_resade_tresorerie_controle_caisse" model="ir.sequence">
        <field name="name">RESADE Contrôle hebdomadaire de caisse</field>
        <field name="code">resade.tresorerie.controle.caisse</field>
        <field name="prefix">CTRL-CAISSE-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_resade_tresorerie_reconstitution" model="ir.sequence">
        <field name="name">RESADE Reconstitution de caisse</field>
        <field name="code">resade.tresorerie.reconstitution</field>
        <field name="prefix">RECONST-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>

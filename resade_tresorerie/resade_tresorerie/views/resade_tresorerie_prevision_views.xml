<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resade_tresorerie_prevision_form" model="ir.ui.view">
        <field name="name">resade.tresorerie.prevision.form</field>
        <field name="model">resade.tresorerie.prevision</field>
        <field name="arch" type="xml">
            <form string="Prévisionnel de Décaissements">
                <header>
                    <button name="action_generer" type="object" string="Actualiser le prévisionnel"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_generation" readonly="1"/>
                            <field name="genere_par" readonly="1"/>
                        </group>
                        <group>
                            <field name="nb_lignes" readonly="1"/>
                            <field name="total_previsionnel" readonly="1" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Décaissements prévus">
                            <field name="ligne_ids" readonly="1">
                                <list decoration-warning="True">
                                    <field name="date_prevue"/>
                                    <field name="source"/>
                                    <field name="objet"/>
                                    <field name="fournisseur"/>
                                    <field name="montant" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <button name="action_voir_dossier" type="object"
                                            string="Voir dossier" icon="fa-external-link"/>
                                </list>
                            </field>
                        </page>
                        <page string="Analyse CAF">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_resade_tresorerie_prevision_list" model="ir.ui.view">
        <field name="name">resade.tresorerie.prevision.list</field>
        <field name="model">resade.tresorerie.prevision</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_generation"/>
                <field name="nb_lignes"/>
                <field name="total_previsionnel" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_resade_tresorerie_prevision" model="ir.actions.act_window">
        <field name="name">Prévisionnel de Décaissements</field>
        <field name="res_model">resade.tresorerie.prevision</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez un nouveau prévisionnel pour lister les décaissements engagés en attente de paiement.
            </p>
        </field>
    </record>
</odoo>

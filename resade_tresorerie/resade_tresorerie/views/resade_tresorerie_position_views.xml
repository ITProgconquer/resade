<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resade_tresorerie_position_form" model="ir.ui.view">
        <field name="name">resade.tresorerie.position.form</field>
        <field name="model">resade.tresorerie.position</field>
        <field name="arch" type="xml">
            <form string="Position de Trésorerie">
                <header>
                    <button name="action_generer" type="object" string="Actualiser les soldes"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_generation" readonly="1"/>
                            <field name="genere_par" readonly="1"/>
                        </group>
                        <group>
                            <field name="nb_comptes" readonly="1"/>
                            <field name="total_disponible" readonly="1" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Comptes bancaires / caisses">
                            <field name="ligne_ids" readonly="1">
                                <list>
                                    <field name="journal_id"/>
                                    <field name="compte_id"/>
                                    <field name="solde" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observations">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_resade_tresorerie_position_list" model="ir.ui.view">
        <field name="name">resade.tresorerie.position.list</field>
        <field name="model">resade.tresorerie.position</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_generation"/>
                <field name="nb_comptes"/>
                <field name="total_disponible" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_resade_tresorerie_position" model="ir.actions.act_window">
        <field name="name">Position de Trésorerie</field>
        <field name="res_model">resade.tresorerie.position</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez une nouvelle position pour photographier les soldes bancaires actuels.
            </p>
        </field>
    </record>
</odoo>

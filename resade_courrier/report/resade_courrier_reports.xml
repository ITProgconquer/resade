<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_resade_courrier_entrant" model="ir.actions.report">
        <field name="name">Fiche d'Affectation (RESADE-F-GC-01-02)</field>
        <field name="model">resade.courrier.entrant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">resade_courrier.report_resade_courrier_entrant_template</field>
        <field name="report_file">resade_courrier.report_resade_courrier_entrant_template</field>
        <field name="print_report_name">'FA_%s' % (object.numero or 'Nouveau').replace('/', '-')</field>
        <field name="binding_model_id" ref="model_resade_courrier_entrant"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_resade_courrier_sortant" model="ir.actions.report">
        <field name="name">Courrier officiel (RESADE-F-GC-02-01)</field>
        <field name="model">resade.courrier.sortant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">resade_courrier.report_resade_courrier_sortant_template</field>
        <field name="report_file">resade_courrier.report_resade_courrier_sortant_template</field>
        <field name="print_report_name">'Courrier_%s' % (object.numero or 'brouillon').replace('/', '-')</field>
        <field name="binding_model_id" ref="model_resade_courrier_sortant"/>
        <field name="binding_type">report</field>
    </record>

</odoo>

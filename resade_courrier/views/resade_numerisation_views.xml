<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resade_numerisation_form" model="ir.ui.view">
        <field name="name">resade.numerisation.form</field>
        <field name="model">resade.numerisation</field>
        <field name="arch" type="xml">
            <form string="Numérisation de Document Stratégique">
                <header>
                    <button name="action_demarrer_numerisation" string="Démarrer la numérisation"
                            type="object" class="btn-primary"
                            invisible="state != 'a_numeriser'"
                            groups="resade_courrier.group_resade_courrier_aa"/>
                    <button name="action_soumettre_controle" string="Soumettre au contrôle qualité"
                            type="object" class="btn-primary"
                            invisible="state != 'en_cours'"
                            groups="resade_courrier.group_resade_courrier_aa"/>
                    <button name="action_rejeter" string="Rejeter"
                            type="object" class="btn-danger"
                            invisible="state != 'controle'"
                            groups="resade_courrier.group_resade_courrier_csi"/>
                    <button name="action_valider_controle" string="Valider et verser en GED"
                            type="object" class="btn-success"
                            invisible="state != 'controle'"
                            groups="resade_courrier.group_resade_courrier_csi"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="a_numeriser,en_cours,controle,numerise"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="reference"/>
                        <h1><field name="reference" readonly="1"/></h1>
                        <h2><field name="intitule_document" placeholder="Intitulé du document..."/></h2>
                    </div>
                    <group>
                        <group string="Liste prioritaire (RESADE-F-CA-03-01)">
                            <field name="priorite"/>
                            <field name="classeur_id"/>
                            <field name="chef_dept_demandeur_id"/>
                            <field name="date_inscription"/>
                        </group>
                        <group string="Critères de priorisation">
                            <field name="valeur_juridique"/>
                            <field name="valeur_financiere"/>
                            <field name="risque_perte"/>
                            <field name="irremplacable"/>
                        </group>
                    </group>
                    <group string="Validation de la liste">
                        <field name="valide_par_caf"/>
                        <field name="approuve_par_de"/>
                    </group>
                    <notebook>
                        <page string="Numérisation" name="numerisation"
                              invisible="state not in ['en_cours','controle','rejete','numerise']">
                            <group>
                                <group>
                                    <field name="date_debut_numerisation"/>
                                    <field name="date_fin_numerisation"/>
                                    <field name="resolution_dpi"/>
                                    <field name="format_fichier"/>
                                </group>
                                <group>
                                    <field name="fichier_numerise" filename="fichier_numerise_filename" widget="binary"/>
                                    <field name="fichier_numerise_filename"/>
                                </group>
                            </group>
                        </page>
                        <page string="Contrôle qualité (RESADE-F-CA-03-02)" name="controle"
                              invisible="state not in ['controle','rejete','numerise']">
                            <group>
                                <group>
                                    <field name="controle_lisibilite_ok"/>
                                    <field name="controle_integrite_ok"/>
                                    <field name="controle_nommage_ok"/>
                                </group>
                                <group>
                                    <field name="controle_par_id"/>
                                    <field name="date_controle"/>
                                </group>
                            </group>
                            <field name="motif_rejet" invisible="state != 'rejete'"/>
                        </page>
                        <page string="Versement GED et original" name="ged"
                              invisible="state != 'numerise'">
                            <group>
                                <field name="ged_document_id"/>
                                <field name="original_conserve"/>
                                <field name="etiquette_apposee"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_resade_numerisation_list" model="ir.ui.view">
        <field name="name">resade.numerisation.list</field>
        <field name="model">resade.numerisation</field>
        <field name="arch" type="xml">
            <list decoration-danger="priorite == 'p1' and state != 'numerise'"
                  decoration-success="state == 'numerise'"
                  decoration-muted="state == 'rejete'">
                <field name="reference"/>
                <field name="intitule_document"/>
                <field name="priorite"/>
                <field name="chef_dept_demandeur_id"/>
                <field name="date_inscription"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_resade_numerisation_search" model="ir.ui.view">
        <field name="name">resade.numerisation.search</field>
        <field name="model">resade.numerisation</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="intitule_document"/>
                <field name="chef_dept_demandeur_id"/>
                <filter string="P1 - Urgentes" name="p1" domain="[('priorite', '=', 'p1')]"/>
                <separator/>
                <filter string="À numériser" name="a_numeriser" domain="[('state', '=', 'a_numeriser')]"/>
                <filter string="En cours" name="en_cours" domain="[('state', 'in', ['en_cours', 'controle'])]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Priorité" name="group_priorite" context="{'group_by': 'priorite'}"/>
                    <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_resade_numerisation" model="ir.actions.act_window">
        <field name="name">Numérisation des Documents Stratégiques</field>
        <field name="res_model">resade.numerisation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_a_numeriser': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun document inscrit sur la liste prioritaire</p>
            <p>Processus P-CA-03 — Numérisation des documents physiques stratégiques RESADE</p>
        </field>
    </record>
</odoo>

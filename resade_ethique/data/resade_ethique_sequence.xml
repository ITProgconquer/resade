<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_resade_ethique_soumission" model="ir.sequence">
            <field name="name">RESADE Éthique - Soumission éthique/réglementaire</field>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_resade_ethique_risque_tree" model="ir.ui.view">
        <field name="name">resade.ethique.risque.tree</field>
        <field name="model">resade.ethique.risque</field>
        <field name="arch" type="xml">
            <list string="Registre des risques institutionnels" decoration-danger="criticite &gt;= 6" decoration-warning="criticite &gt;= 3 and criticite &lt; 6">
                <field name="name"/>
                <field name="intitule_risque"/>
                <field name="categorie"/>
                <field name="incidence"/>
                <field name="occurrence"/>
                <field name="criticite"/>
                <field name="proprietaire_id"/>
                <field name="statut" widget="badge"
                       decoration-success="statut == 'maitrise'"
                       decoration-muted="statut == 'clos'"/>
            </list>
        </field>
    </record>

    <record id="view_resade_ethique_risque_form" model="ir.ui.view">
        <field name="name">resade.ethique.risque.form</field>
        <field name="model">resade.ethique.risque</field>
        <field name="arch" type="xml">
            <form string="Risque institutionnel">
                <header>
                    <button name="action_marquer_maitrise" string="Marquer comme maîtrisé" type="object"
                            class="oe_highlight" invisible="statut != 'actif'"/>
                    <button name="action_cloturer" string="Clôturer" type="object"
                            invisible="statut != 'maitrise'"/>
                    <button name="action_reactiver" string="Réactiver" type="object"
                            invisible="statut == 'actif'"/>
                    <field name="statut" widget="statusbar" statusbar_visible="actif,maitrise,clos"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="intitule_risque"/>
                        <h1><field name="intitule_risque"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="categorie"/>
                            <field name="origine_ps_2026_2030"/>
                            <field name="proprietaire_id"/>
                        </group>
                        <group>
                            <field name="incidence"/>
                            <field name="occurrence"/>
                            <field name="criticite"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="date_identification"/>
                        <field name="date_derniere_revue"/>
                        <field name="date_prochaine_revue"/>
                    </group>
                    <notebook>
                        <page string="Plans de mitigation / continuité">
                            <field name="plan_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="type_plan"/>
                                    <field name="responsable_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_resade_ethique_risque_search" model="ir.ui.view">
        <field name="name">resade.ethique.risque.search</field>
        <field name="model">resade.ethique.risque</field>
        <field name="arch" type="xml">
            <search string="Rechercher un risque">
                <field name="name"/>
                <field name="intitule_risque"/>
                <filter string="Risques critiques (≥6)" name="critique" domain="[('criticite','&gt;=',6)]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Catégorie" name="group_categorie" context="{'group_by': 'categorie'}"/>
                    <filter string="Statut" name="group_statut" context="{'group_by': 'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_resade_ethique_risque" model="ir.actions.act_window">
        <field name="name">Registre des risques (P-GRI-01)</field>
        <field name="res_model">resade.ethique.risque</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ajoutez un risque au registre institutionnel</p>
            <p>Basé sur les 19 risques identifiés dans le Plan Stratégique 2026-2030.</p>
        </field>
    </record>

</odoo>

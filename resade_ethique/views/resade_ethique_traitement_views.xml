<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_resade_ethique_traitement_tree" model="ir.ui.view">
        <field name="name">resade.ethique.traitement.tree</field>
        <field name="model">resade.ethique.traitement</field>
        <field name="arch" type="xml">
            <list string="Registre des traitements de données personnelles">
                <field name="name"/>
                <field name="intitule_traitement"/>
                <field name="categorie_donnees"/>
                <field name="donnees_sensibles"/>
                <field name="declare_cil"/>
                <field name="date_derniere_revue"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'actif'"
                       decoration-muted="state == 'archive'"/>
            </list>
        </field>
    </record>

    <record id="view_resade_ethique_traitement_form" model="ir.ui.view">
        <field name="name">resade.ethique.traitement.form</field>
        <field name="model">resade.ethique.traitement</field>
        <field name="arch" type="xml">
            <form string="Traitement de données personnelles">
                <header>
                    <button name="action_mettre_en_revue" string="Mettre en revue" type="object"
                            invisible="state != 'actif'"/>
                    <button name="action_reactiver" string="Réactiver" type="object"
                            class="oe_highlight" invisible="state != 'en_revue'"/>
                    <button name="action_archiver" string="Archiver" type="object"
                            invisible="state == 'archive'"/>
                    <field name="state" widget="statusbar" statusbar_visible="actif,en_revue,archive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="intitule_traitement"/>
                        <h1><field name="intitule_traitement"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="categorie_donnees"/>
                            <field name="donnees_sensibles"/>
                            <field name="base_legale"/>
                            <field name="duree_conservation"/>
                        </group>
                        <group>
                            <field name="responsable_traitement_id"/>
                            <field name="correspondant_donnees_id"/>
                            <field name="declare_cil"/>
                            <field name="date_declaration_cil" invisible="not declare_cil"/>
                        </group>
                    </group>
                    <group>
                        <field name="finalite"/>
                        <field name="mesures_securite"/>
                    </group>
                    <group>
                        <field name="date_derniere_revue"/>
                        <field name="date_prochaine_revue"/>
                        <field name="incident_ids_count"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_resade_ethique_traitement" model="ir.actions.act_window">
        <field name="name">Registre des traitements (P-DC-03)</field>
        <field name="res_model">resade.ethique.traitement</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Ajoutez un traitement de données personnelles au registre</p>
        </field>
    </record>

</odoo>
